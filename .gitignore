## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# IIS Express
.vs/
iisexpress/
*.vspscc
*.vssscc

# Azure
*.azurePubxml
*.pubxml
*.publishproj

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
!**/[Pp]ackages/build/
# Keep lock file for reproducibility
packages.lock.json

# Dotnet tools
.dotnet/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Coverlet / coverage
coverage/
*.coverage
*.coveragexml

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# DotCover
*.dotCover

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# StyleCop
StyleCopReport.xml

# Backup & report files
*.bak
*.backup
*.old

# SQL Server files
*.mdf
*.ldf

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Publish output
publish/

# Blazor
wwwroot/css/app.bundle.css
wwwroot/css/app.bundle.css.map

# Node modules (if frontend inside project)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

#Database Connection
src/GoodHamburguer.API/appsettings.json